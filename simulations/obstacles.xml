<config>
    <!--
        Cenário ECHOSAR-Net — 3 edifícios urbanos de concreto.
        Área: 5000 x 5000 m  |  Drones: Z=100 m (constante)  |  Embarcações: Z=1,5 m

        ALTURA: 120 m (acima dos 100 m dos drones) → qualquer caminho
        horizontal entre drone e embarcação que cruzar o footprint do
        edifício SEMPRE intersecta o volume [0..120 m], garantindo
        atenuação dielétrica pela DielectricObstacleLoss independentemente
        da posição vertical exata do drone.

        Material 'concrete': resistivity=100 Ω·m, ε_r=4.5
        Atenuação estimada: ~0.24 dB/m → para 10 m de espessura ≈ 2.4 dB
        (+ ~1.5 dB de reflexão em 2 interfaces); links marginais (perto de
        800 m de alcance) são bloqueados mesmo com poucos metros de concreto.

        Posicionamento:
          Obs-A (noroeste-centro) — cobre corredor drone↔equipes SW/SE
          Obs-B (centro)          — cobre corredor drone↔equipe central/NE
          Obs-C (leste-centro)    — cobre corredor drone↔equipes NW/SW
    -->

    <!-- Obs-A: 400 x 300 x 120 m — noroeste-centro -->
    <object id="1"
            name="Edificio-A"
            position="center 1300 2000 60"
            orientation="0 0 0"
            shape="cuboid 400 300 120"
            material="concrete"
            line-color="60 60 60"
            fill-color="140 140 140"
            opacity="0.75"/>

    <!-- Obs-B: 500 x 500 x 120 m — centro -->
    <object id="2"
            name="Edificio-B"
            position="center 2700 2200 60"
            orientation="0 0 0"
            shape="cuboid 500 500 120"
            material="concrete"
            line-color="60 60 60"
            fill-color="120 120 120"
            opacity="0.75"/>

    <!-- Obs-C: 350 x 400 x 120 m — leste-centro -->
    <object id="3"
            name="Edificio-C"
            position="center 3800 3200 60"
            orientation="0 0 0"
            shape="cuboid 350 400 120"
            material="concrete"
            line-color="60 60 60"
            fill-color="140 140 140"
            opacity="0.75"/>
</config>
