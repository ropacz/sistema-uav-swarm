<config>
    <!--
        Cenário ECHOSAR-Net — 3 edifícios urbanos de concreto.
        Área: 5000 x 5000 m  |  Drones: Z=100 m (constante)  |  Embarcações: Z=1,5 m

        POSICIONAMENTO: próximo das posições iniciais de 3 equipes de resgate,
        bloqueando a linha de visada de drones vindos do interior da área.

        ALTURA: 120 m (acima dos 100 m dos drones) — garante que qualquer
        cruzamento horizontal do footprint ativa DielectricObstacleLoss.

        Material 'concrete': ε_r=4,5, σ≈0,01 S/m → ~0,24 dB/m @ 2,4 GHz.

        Equipes de referência (posições iniciais):
          team0 (SW)     → (600, 4400)   → Obs-A em (1050, 4100)
          team4 (Centro) → (2500, 2500)  → Obs-B em (2750, 2750)
          team2 (SE)     → (4400, 4400)  → Obs-C em (4050, 4100)
    -->

    <!-- Obs-A: 350 x 350 x 120 m — próximo de team0 (SW) -->
    <object id="1"
            name="Edificio-A"
            position="center 1050 4100 60"
            orientation="0 0 0"
            shape="cuboid 350 350 120"
            material="concrete"
            line-color="60 60 60"
            fill-color="140 140 140"
            opacity="0.80"/>

    <!-- Obs-B: 400 x 400 x 120 m — próximo de team4 (Centro) -->
    <object id="2"
            name="Edificio-B"
            position="center 2750 2750 60"
            orientation="0 0 0"
            shape="cuboid 400 400 120"
            material="concrete"
            line-color="60 60 60"
            fill-color="120 120 120"
            opacity="0.80"/>

    <!-- Obs-C: 350 x 350 x 120 m — próximo de team2 (SE) -->
    <object id="3"
            name="Edificio-C"
            position="center 4050 4100 60"
            orientation="0 0 0"
            shape="cuboid 350 350 120"
            material="concrete"
            line-color="60 60 60"
            fill-color="140 140 140"
            opacity="0.80"/>
</config>
